<?xml version="1.0" encoding="UTF-8"?>
<extension type="module" client="site" method="upgrade">
    <name>MOD_OPENINGHOURS</name>
    <description>MOD_OPENINGHOURS_XML_DESCRIPTION</description>
    <author>Jeroen Moolenschot | Joomill</author>
    <authorEmail>info@joomill.nl</authorEmail>
    <authorUrl>https://www.joomill-extensions.com</authorUrl>
    <license>GNU General Public License version 3 or later</license>
    <creationDate>June 2026</creationDate>
    <copyright>(C) 2026 Joomill Extensions</copyright>
    <version>6.2.0</version>
    <namespace path="src">Joomill\Module\Openinghours</namespace>

    <!-- Scripts to run on installation -->
    <scriptfile>script.php</scriptfile>

    <!-- Files -->
    <files>
        <folder>css</folder>
        <folder>language</folder>
        <folder module="mod_openinghours">services</folder>
        <folder>src</folder>
        <folder>tmpl</folder>
    </files>

    <!-- Config -->
    <config>
        <fields name="params" addfieldprefix="Joomill\Module\Openinghours\Site\Field">

            <fieldset name="basic">
                <field
                        name="upgrade_note"
                        type="note"
                        label="MOD_OPENINGHOURS_UPGRADE_LABEL"
                        description="MOD_OPENINGHOURS_UPGRADE_DESC"
                />
            </fieldset>

            <fieldset
                    name="regular"
                    label="MOD_OPENINGHOURS_REGULAR_HOURS_LABEL"
                    description="MOD_OPENINGHOURS_REGULAR_HOURS_NOTE"
            >
                <field name="Mondaytimes1" type="text" default="08:30 - 18:00" label="MONDAY" description="MOD_OPENINGHOURS_REGULAR_HOURS_DESC"/>
                <field name="Tuesdaytimes1" type="text" default="08:30 - 18:00" label="TUESDAY" description="MOD_OPENINGHOURS_REGULAR_HOURS_DESC"/>
                <field name="Wednesdaytimes1" type="text" default="08:30 - 18:00" label="WEDNESDAY" description="MOD_OPENINGHOURS_REGULAR_HOURS_DESC"/>
                <field name="Thursdaytimes1" type="text" default="08:30 - 18:00" label="THURSDAY" description="MOD_OPENINGHOURS_REGULAR_HOURS_DESC"/>
                <field name="Fridaytimes1" type="text" default="08:30 - 18:00" label="FRIDAY" description="MOD_OPENINGHOURS_REGULAR_HOURS_DESC"/>
                <field name="Saturdaytimes1" type="text" default="08:30 - 18:00" label="SATURDAY" description="MOD_OPENINGHOURS_REGULAR_HOURS_DESC"/>
                <field name="Sundaytimes1" type="text" default="CLOSED" label="SUNDAY" description="MOD_OPENINGHOURS_REGULAR_HOURS_DESC"/>

                <field
                        name="secondtimeslot"
                        type="pro"
                        label="MOD_OPENINGHOURS_SECOND_TIMESLOT_LABEL"
                        description="MOD_OPENINGHOURS_SECOND_TIMESLOT_DESC"
                />
            </fieldset>

            <fieldset
                    name="exceptional"
                    label="MOD_OPENINGHOURS_EXCEP_HOURS_LABEL"
                    description="MOD_OPENINGHOURS_EXCEP_HOURS_NOTE_DESC"
            >
                <field
                        name="exceptional"
                        type="pro"
                        label="MOD_OPENINGHOURS_EXCEP_HOURS_LABEL"
                        description="MOD_OPENINGHOURS_EXCEP_HOURS_NOTE_DESC"
                />
            </fieldset>

            <fieldset
                    name="display"
                    label="MOD_OPENINGHOURS_DISPLAY_LABEL"
            >
                <field
                        name="Width"
                        type="text"
                        default="100%"
                        label="MOD_OPENINGHOURS_DISPLAY_WIDTH_LABEL"
                        description="MOD_OPENINGHOURS_DISPLAY_WIDTH_DESC"
                />
                <field
                        name="Dayalign"
                        type="list"
                        default="left"
                        label="MOD_OPENINGHOURS_DISPLAY_DAYALIGN_LABEL"
                        description="MOD_OPENINGHOURS_DISPLAY_ALIGN_DESC"
                >
                    <option value="left">MOD_OPENINGHOURS_LEFT</option>
                    <option value="center">MOD_OPENINGHOURS_CENTER</option>
                    <option value="right">MOD_OPENINGHOURS_RIGHT</option>
                </field>
                <field
                        name="Timealign"
                        type="list"
                        default="right"
                        label="MOD_OPENINGHOURS_DISPLAY_TIMEALIGN_LABEL"
                        description="MOD_OPENINGHOURS_DISPLAY_ALIGN_DESC"
                >
                    <option value="left">MOD_OPENINGHOURS_LEFT</option>
                    <option value="center">MOD_OPENINGHOURS_CENTER</option>
                    <option value="right">MOD_OPENINGHOURS_RIGHT</option>
                </field>
                <field
                        name="Weekstart"
                        type="list"
                        default="2"
                        label="MOD_OPENINGHOURS_DISPLAY_WEEKSTART_LABEL"
                        description="MOD_OPENINGHOURS_DISPLAY_WEEKSTART_DESC"
                >
                    <option value="3">SATURDAY</option>
                    <option value="1">SUNDAY</option>
                    <option value="2">MONDAY</option>
                </field>
                <field
                        name="Timeformat"
                        type="text"
                        default="H:i"
                        label="MOD_OPENINGHOURS_DISPLAY_TIMEFORMAT_LABEL"
                        description="MOD_OPENINGHOURS_DISPLAY_TIMEFORMAT_DESC"
                />
                <field
                        name="Timezone"
                        type="timezone"
                        default="UTC"
                        label="MOD_OPENINGHOURS_DISPLAY_TIMEZONE_LABEL"
                        description="MOD_OPENINGHOURS_DISPLAY_TIMEZONE_DESC"
                />

                <field name="next7days" type="pro" label="MOD_OPENINGHOURS_NEXT7DAYS" description="MOD_OPENINGHOURS_DISPLAY_WEEKSTART_DESC"/>
                <field name="Onlytoday" type="pro" label="MOD_OPENINGHOURS_DISPLAY_ONLYTODAY_LABEL" description="MOD_OPENINGHOURS_DISPLAY_ONLYTODAY_DESC"/>
                <field name="Monfri" type="pro" label="MOD_OPENINGHOURS_DISPLAY_MONFRI_LABEL" description="MOD_OPENINGHOURS_DISPLAY_MONFRI_DESC"/>
                <field name="Viewdates" type="pro" label="MOD_OPENINGHOURS_DISPLAY_DATES_LABEL" description="MOD_OPENINGHOURS_DISPLAY_DATES_DESC"/>
                <field name="Dateformat" type="pro" label="MOD_OPENINGHOURS_DISPLAY_DATEFORMAT_LABEL" description="MOD_OPENINGHOURS_DISPLAY_DATEFORMAT_DESC"/>
                <field name="Font" type="pro" label="MOD_OPENINGHOURS_DISPLAY_FONT_LABEL" description="MOD_OPENINGHOURS_DISPLAY_FONT_DESC"/>
                <field name="Fontsize" type="pro" label="MOD_OPENINGHOURS_DISPLAY_FONTSIZE_LABEL" description="MOD_OPENINGHOURS_DISPLAY_FONTSIZE_DESC"/>
            </fieldset>

            <fieldset
                    name="highlight"
                    label="MOD_OPENINGHOURS_DISPLAY_HIGHLIGHTS_LABEL"
            >
                <field
                        name="Highlight"
                        type="radio"
                        class="btn-group"
                        default="1"
                        label="MOD_OPENINGHOURS_DISPLAY_HIGHLIGHT_LABEL"
                        description="MOD_OPENINGHOURS_DISPLAY_HIGHLIGHT_DESC"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                        name="Highlightcolor"
                        type="color"
                        default="#3990BD"
                        label="MOD_OPENINGHOURS_DISPLAY_HIGHLIGHTCOLOR_LABEL"
                        description="MOD_OPENINGHOURS_DISPLAY_HIGHLIGHTCOLOR_DESC"
                        showon="Highlight:1"
                />

                <field name="Highlightbold" type="pro" label="MOD_OPENINGHOURS_DISPLAY_HIGHLIGHTBOLD_LABEL" description="MOD_OPENINGHOURS_DISPLAY_HIGHLIGHTBOLD_DESC"/>
                <field name="Highlightitalic" type="pro" label="MOD_OPENINGHOURS_DISPLAY_HIGHLIGHTITALIC_LABEL" description="MOD_OPENINGHOURS_DISPLAY_HIGHLIGHTITALIC_DESC"/>
            </fieldset>

            <fieldset
                    name="notes"
                    label="MOD_OPENINGHOURS_DISPLAY_NOTES_LABEL"
            >
                <field name="Viewnotes" type="pro" label="MOD_OPENINGHOURS_DISPLAY_VIEWNOTES_LABEL" description="MOD_OPENINGHOURS_DISPLAY_NOTES_DESC"/>
            </fieldset>

            <fieldset
                    name="current"
                    label="MOD_OPENINGHOURS_CURRENTLY_OPEN_LABEL"
            >
                <field name="Showopen" type="pro" label="MOD_OPENINGHOURS_SHOW_CURRENTLY_OPEN_LABEL" description="MOD_OPENINGHOURS_SHOW_CURRENTLY_OPEN_DESC"/>
                <field name="Showclosed" type="pro" label="MOD_OPENINGHOURS_SHOW_CURRENTLY_CLOSED_LABEL" description="MOD_OPENINGHOURS_SHOW_CURRENTLY_CLOSED_DESC"/>
            </fieldset>

            <fieldset
                    name="microdata"
                    label="MOD_OPENINGHOURS_MICRODATA_LABEL"
            >
                <field
                        name="Usemicro"
                        type="radio"
                        class="btn-group"
                        default="1"
                        label="MOD_OPENINGHOURS_USE_MICRODATA_LABEL"
                        description="MOD_OPENINGHOURS_USE_MICRODATA_DESC"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>

                <field name="microdatabusiness" type="pro" label="MOD_OPENINGHOURS_MICRODATA_BUSINESS_LABEL" description="MOD_OPENINGHOURS_MICRODATA_BUSINESS_DESC"/>
            </fieldset>

            <fieldset
                    name="contentplugin"
                    label="MOD_OPENINGHOURS_CONTENTPLUGIN_LABEL"
            >
                <field name="contentplugin" type="pro" label="MOD_OPENINGHOURS_CONTENTPLUGIN_LABEL" description="MOD_OPENINGHOURS_CONTENTPLUGIN_DESC"/>
            </fieldset>

            <fieldset name="advanced">
                <field
                        name="layout"
                        type="modulelayout"
                        label="JFIELD_ALT_LAYOUT_LABEL"
                        class="custom-select-color-state"
                />
                <field
                        name="moduleclass_sfx"
                        type="textarea"
                        rows="3"
                        label="COM_MODULES_FIELD_MODULECLASS_SFX_LABEL"
                />
                <field
                        type="editor"
                        name="custom_css"
                        label="MOD_OPENINGHOURS_CUSTOM_CSS_LABEL"
                        default=""
                        rows="10"
                        buttons="no"
                        editor="codemirror|none"
                        filter="raw"
                />
                <field
                        name="Debug"
                        type="radio"
                        class="btn-group"
                        default="0"
                        label="MOD_OPENINGHOURS_DEBUG_LABEL"
                        description="MOD_OPENINGHOURS_DEBUG_DESC"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                        name="Footer"
                        type="radio"
                        class="btn-group"
                        default="1"
                        label="MOD_OPENINGHOURS_BASIC_FOOTER_LABEL"
                        description="MOD_OPENINGHOURS_BASIC_FOOTER_DESC"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
            </fieldset>
        </fields>
    </config>

    <!-- Help button URL -->
    <help key="" url="MOD_OPENINGHOURS_HELP_URL" />

    <!-- Update servers -->
    <changelogurl>
        <![CDATA[https://www.joomill-extensions.com/index.php?option=com_ochsubscriptions&amp;view=changelog&amp;format=xml&amp;cat=1]]>
    </changelogurl>

    <updateservers>
        <server type="extension" name="Opening Hours FREE">
            <![CDATA[https://www.joomill-extensions.com/index.php?option=com_ochsubscriptions&amp;view=updater&amp;format=xml&amp;cat=1]]>
        </server>
    </updateservers>
</extension>
